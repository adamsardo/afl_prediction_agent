AFL_AGENT_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/afl_agent
AFL_AGENT_DEFAULT_LLM_PROVIDER=heuristic
AFL_AGENT_DEFAULT_ANALYST_MODEL=heuristic-analyst-v1
AFL_AGENT_DEFAULT_CASE_MODEL=heuristic-case-v1
AFL_AGENT_DEFAULT_FINAL_MODEL=heuristic-final-v1
AFL_AGENT_CODEX_BIN=codex
AFL_AGENT_CODEX_STARTUP_TIMEOUT_SECONDS=15
AFL_AGENT_CODEX_TURN_TIMEOUT_SECONDS=120
